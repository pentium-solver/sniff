#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cleanup() {
  kill $BACKEND_PID $FRONTEND_PID 2>/dev/null
  wait $BACKEND_PID $FRONTEND_PID 2>/dev/null
}
trap cleanup EXIT INT TERM

# Start Go backend on :9090 (API only, no browser open)
echo "Starting backend on :9090..."
cd "$ROOT_DIR"
SNIFF_NO_OPEN=1 GOCACHE="${GOCACHE:-/tmp/go-build}" go run . --web &
BACKEND_PID=$!

# Start Next.js dev server on :3000
echo "Starting frontend on :3000..."
cd "$ROOT_DIR/site"
bun dev &
FRONTEND_PID=$!

# Open the Next.js frontend
sleep 2
open http://localhost:3000

echo ""
echo "  Backend API: http://localhost:9090"
echo "  Frontend:    http://localhost:3000"
echo ""

wait
